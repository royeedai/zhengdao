{
  "name": "zhengdao",
  "version": "1.9.4",
  "productName": "证道",
  "description": "证道 - 沉浸式桌面端网文创作软件",
  "author": "royeedai",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/royeedai/zhengdao",
  "bugs": {
    "url": "https://github.com/royeedai/zhengdao/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/royeedai/zhengdao.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "predev": "electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --build --pretty false",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ux:ledger": "node scripts/ux/generate-surface-ledger.mjs",
    "ux:ledger:check": "node scripts/ux/generate-surface-ledger.mjs --check",
    "assets:icons": "bash scripts/assets/generate-icons.sh",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "release:prepare": "node scripts/release/prepare-release.mjs",
    "release:publish": "node scripts/release/publish-release.mjs",
    "release:github": "electron-builder --config electron-builder.config.ts --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "keywords": [
    "novel-writing",
    "writing-tool",
    "desktop-app",
    "electron",
    "web-novel",
    "zhengdao"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/gemini-cli": "0.38.2",
    "@tiptap/core": "^2.11.0",
    "@tiptap/extension-history": "^2.11.0",
    "@tiptap/extension-mention": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/react": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "better-sqlite3": "^11.0.0",
    "dagre": "^0.8.5",
    "docx": "^9.0.0",
    "electron-updater": "^6.8.3",
    "json5": "^2.2.3",
    "lucide-react": "^0.460.0",
    "react": "^18.3.0",
    "react-d3-tree": "^3.6.6",
    "react-dom": "^18.3.0",
    "react-resizable-panels": "^4.10.0",
    "reactflow": "^11.11.4",
    "tippy.js": "^6.3.7",
    "vis-data": "^7.1.10",
    "vis-timeline": "^7.7.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/dagre": "^0.7.54",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
